{
  "Description": "IAM policy for agent developers to run update-agent.sh. Attach this to the developer role/group. No IAM or CloudFormation write access needed.",
  "PolicyName": "AIQATestEngine-DeveloperUpdatePolicy",
  "PolicyDocument": {
    "Version": "2012-10-17",
    "Statement": [
      {
        "Sid": "UploadSourceToDeployBucket",
        "Effect": "Allow",
        "Action": [
          "s3:PutObject"
        ],
        "Resource": "arn:aws:s3:::ai-qa-test-engine-deploy-*/*"
      },
      {
        "Sid": "TriggerAndMonitorCodeBuild",
        "Effect": "Allow",
        "Action": [
          "codebuild:StartBuild",
          "codebuild:BatchGetBuilds"
        ],
        "Resource": "arn:aws:codebuild:*:*:project/ai-qa-test-engine-*"
      },
      {
        "Sid": "ReadStackOutputs",
        "Effect": "Allow",
        "Action": [
          "cloudformation:DescribeStacks"
        ],
        "Resource": "arn:aws:cloudformation:*:*:stack/ai-qa-test-engine/*"
      },
      {
        "Sid": "UpdateAgentCoreRuntimes",
        "Effect": "Allow",
        "Action": [
          "bedrock-agentcore:UpdateAgentRuntime",
          "bedrock-agentcore:GetAgentRuntime"
        ],
        "Resource": "arn:aws:bedrock-agentcore:*:*:runtime/*"
      },
      {
        "Sid": "InvokeAgentForTesting",
        "Effect": "Allow",
        "Action": [
          "bedrock-agentcore:InvokeAgentRuntime"
        ],
        "Resource": "arn:aws:bedrock-agentcore:*:*:runtime/*"
      },
      {
        "Sid": "PassExecutionRoleToAgentCore",
        "Effect": "Allow",
        "Action": [
          "iam:PassRole"
        ],
        "Resource": "arn:aws:iam::*:role/ai-qa-test-engine-agentcore-role",
        "Condition": {
          "StringEquals": {
            "iam:PassedToService": "bedrock-agentcore.amazonaws.com"
          }
        }
      },
      {
        "Sid": "GetCallerIdentity",
        "Effect": "Allow",
        "Action": [
          "sts:GetCallerIdentity"
        ],
        "Resource": "*"
      }
    ]
  }
}
