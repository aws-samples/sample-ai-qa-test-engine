# AI QA Test Engine — Sample Configuration
# Copy this to .env and adjust values as needed:
#   cp .env.example .env

# Feature directory (relative to where CLI is run from)
FEATURE_DIR=features

# Translation cache directory
TRANSLATED_FEATURE_DIR=translated
CACHE_DIR=translated

# Custom functions file
CUSTOM_FUNCTIONS_FILE=custom_functions.py

# Tag-to-URL mappings (JSON file or individual env vars)
TAG_URL_MAP_FILE=tag-url-mapping.json
DEFAULT_TEST_URL=https://nova.amazon.com/act/gym/next-dot/
GHERKIN_TAG_NEXTDOTGYM=https://nova.amazon.com/act/gym/next-dot/

# Browser mode: headed | headless
BROWSER_MODE=headed

# Reports output directory
REPORT_DIR=reports

# Video recording (disabled by default)
ENABLE_VIDEO_RECORDING=false
VIDEO_RECORDING_DIR=./recordings

# Bedrock model for translation (optional, uses Strands default if not set)
# BEDROCK_MODEL_ID=us.amazon.nova-2-lite-v1:0

# Nova Act model (optional)
# NOVA_ACT_MODEL_ID=nova-act-latest

# Nova Act workflow definition name (optional, auto-created if not set)
# NOVA_ACT_WORKFLOW_DEFINITION_NAME=nova-act-examples
